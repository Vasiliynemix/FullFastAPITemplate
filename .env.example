# ============================================================
# Application
# ============================================================
APP_NAME=fastapi
ENVIRONMENT=dev            # dev | prod
DEBUG=true
HOST=0.0.0.0
PORT=8080
API_V1_PREFIX=/api/v1

# Список origin'ов через запятую (CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================
# DEV host-порты (только проброс наружу из Docker).
# Меняйте, если стандартные порты заняты на хосте. В docker-сети контейнеры
# всегда используют стандартные порты — это не влияет на вариант A.
# В прод-оверлее проброс портов отключён, эти переменные там игнорируются.
# ============================================================
POSTGRES_HOST_PORT=5432       # напр. 5433, если локально уже крутится PostgreSQL
REDIS_HOST_PORT=6379
APP_HOST_PORT=8080
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# ============================================================
# PostgreSQL — пул соединений настроен под высокую нагрузку
# ============================================================
# POSTGRES_HOST/PORT — это адрес, по которому ПОДКЛЮЧАЕТСЯ приложение:
#   вариант A (всё в Docker):  POSTGRES_HOST=postgres, POSTGRES_PORT=5432
#   вариант B (uv на хосте):   POSTGRES_HOST=localhost, POSTGRES_PORT=<POSTGRES_HOST_PORT>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=app
# Размер пула на КАЖДЫЙ воркер. Итог: pool_size * workers <= max_connections PG
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=5
DB_POOL_RECYCLE=1800
DB_ECHO=false
# Подключаемся через PgBouncer (transaction pooling)? true => отключаем prepared
# statements asyncpg. В проде (docker-compose.prod.yml) уже включено + хост=pgbouncer:6432.
DB_PGBOUNCER=false

# ============================================================
# Redis — кэш / rate limit / pub-sub
# ============================================================
# вариант B (uv на хосте): REDIS_HOST=localhost, REDIS_PORT=<REDIS_HOST_PORT>
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=100
REDIS_DEFAULT_TTL=60

# ============================================================
# Rate limiting (Redis-based)
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000      # длинное окно: запросов
RATE_LIMIT_WINDOW=60          #   за столько секунд
# Короткий burst-ярус против спама (0 = выкл). Пример: 20/1с не даст «выстрелить»
# всю минутную квоту за секунду. Блокируется превышение ЛЮБОГО из ярусов.
RATE_LIMIT_BURST=20           # запросов
RATE_LIMIT_BURST_WINDOW=1     #   за столько секунд

# ============================================================
# Search (умный поиск q через pg_trgm, только Postgres)
# ============================================================
# Порог триграммной похожести: ниже => терпимее к опечаткам (ловит перестановки,
# напр. «всая»~«вася»≈0.11), но больше слабых совпадений; выше (0.3) => строже.
SEARCH_SIMILARITY_THRESHOLD=0.1

# ============================================================
# Broker (kafka | rabbitmq | memory)
# ============================================================
# BROKER_ENABLED=false => брокер и консьюмеры не поднимаются, события не публикуются,
# ручка /notifications и outbox-relay отключаются. Включено по умолчанию.
BROKER_ENABLED=true
# Какой брокер использует ПРИЛОЖЕНИЕ:
BROKER_TYPE=memory
BROKER_URL=
BROKER_DEFAULT_TOPIC=events
#
# Три сценария (BROKER_TYPE + BROKER_URL + COMPOSE_PROFILES):
#   1) memory (по умолчанию):     BROKER_TYPE=memory   BROKER_URL=            COMPOSE_PROFILES=
#   2) ЛОКАЛЬНЫЙ kafka в Docker:   BROKER_TYPE=kafka    BROKER_URL=kafka:9092 COMPOSE_PROFILES=kafka
#   3) ЛОКАЛЬНЫЙ rabbitmq в Docker:BROKER_TYPE=rabbitmq BROKER_URL=amqp://guest:guest@rabbitmq:5672/  COMPOSE_PROFILES=rabbitmq
#   4) ВНЕШНИЙ брокер (др. сервер):BROKER_TYPE=kafka    BROKER_URL=my-kafka.example:9092  COMPOSE_PROFILES=  (пусто! контейнер НЕ поднимаем)
#
# COMPOSE_PROFILES читает сам docker compose -> при make up/prod-up нужный брокер
# поднимается автоматически. Пусто => брокер-контейнер не стартует (memory/внешний).
COMPOSE_PROFILES=

# Креды для ЛОКАЛЬНОГО RabbitMQ-контейнера (web-консоль: http://localhost:15672)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_UI_PORT=15672

# ============================================================
# Outbox (transactional outbox)
# ============================================================
# Событие пишется в таблицу outbox_messages в ТОЙ ЖЕ транзакции, что и бизнес-данные;
# релей в воркере публикует его в брокер. Гарантирует, что событие не потеряется, если
# брокер недоступен в момент commit. Осмыслен с durable-брокером (kafka/rabbitmq).
OUTBOX_ENABLED=true
OUTBOX_RELAY_INTERVAL=5.0     # период опроса outbox релеем, сек
OUTBOX_BATCH_SIZE=100         # сколько строк публиковать за проход
OUTBOX_RETENTION_DAYS=7       # через сколько дней чистить опубликованные строки

# ============================================================
# Object storage (S3-совместимое: AWS S3, MinIO, Yandex Object Storage)
# ============================================================
# STORAGE_ENABLED=false (по умолчанию) => S3 не подключается, ручки /files отключены.
# Включайте, только если реально работаете с файлами.
STORAGE_ENABLED=false
STORAGE_PRESIGN_EXPIRE=3600        # срок жизни presigned-ссылки, сек
# S3_ENDPOINT_URL пустой => AWS S3. Для MinIO: http://minio:9000, Yandex: https://storage.yandexcloud.net
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_USE_SSL=true
# Публичный базовый URL (публичный бакет/CDN). Если задан — ссылки отдаются прямые,
# без подписи; иначе генерируется подписанная временная (presigned) ссылка.
S3_PUBLIC_URL=

# ============================================================
# Внешний API сообщений (MessagesClient)
# ============================================================
MESSAGES_API_BASE_URL=https://api.max.example
MESSAGES_API_KEY=

# ============================================================
# Acquiring (платёжный эквайринг)
# ============================================================
# Платёжных систем может работать НЕСКОЛЬКО сразу — у каждой свой *_ENABLED флаг.
# memory — заглушка без сети (тесты/локалка), в ПРОДЕ запрещена (старт упадёт).
# Включённый провайдер без кред -> тоже ошибка на старте (а не на первом платеже).
# Компонент пока не внедрён в роуты — подключите сами (см. app/acquiring/).
ACQUIRING_CURRENCY=RUB
ACQUIRING_RETURN_URL=
ACQUIRING_MEMORY_ENABLED=false
# YooKassa (креды из ЛК)
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Новый провайдер: <NAME>_ENABLED=false + его креды

# ============================================================
# Sentry (error tracking) — включается ТОЛЬКО при заданном DSN
# ============================================================
# Пусто => Sentry выключен (no-op). В Sentry уходят непойманные 500-е (не бизнес-ошибки).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0    # доля транзакций для APM (0 = только ошибки)
SENTRY_RELEASE=                  # версия релиза (напр. git sha) для группировки

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
# Формат КОНСОЛИ: false=человекочитаемо (rich-tracebacks), true=JSON
LOG_JSON=false
# Дублировать логи в ФАЙЛ (JSON) — обычно включают в проде. Ротация по размеру + gzip.
LOG_FILE_ENABLED=false
LOG_FILE_PATH=logs/app.log   # в Docker: /app/logs/app.log (см. bind-mount)
LOG_FILE_MAX_BYTES=52428800  # 50 MB на файл до ротации
LOG_FILE_BACKUP_COUNT=14     # сколько gz-архивов хранить (старые удаляются)

# ============================================================
# Gunicorn (prod)
# ============================================================
# Воркеров на контейнер. 0 => авто (CPU+1, для async-воркеров). В проде с несколькими
# replicas задавайте ЯВНО (cpu_count видит ядра хоста, а не cgroup-лимит контейнера).
# Итог параллелизма = replicas × WEB_CONCURRENCY; следите за лимитом соединений PG.
WEB_CONCURRENCY=0
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5

# ============================================================
# Auth / JWT
# ============================================================
# Главный переключатель JWT. 3 режима авторизации (комбинируется с GLOBAL_API_KEY_ENABLED):
#   AUTH_JWT_ENABLED=true  + GLOBAL_API_KEY_ENABLED=true   => JWT + глобальный ключ (оба)
#   AUTH_JWT_ENABLED=true  + GLOBAL_API_KEY_ENABLED=false  => только JWT
#   AUTH_JWT_ENABLED=false + GLOBAL_API_KEY_ENABLED=true   => только глобальный ключ
#   (false + false запрещено — сервис остался бы без защиты, ошибка на старте)
AUTH_JWT_ENABLED=true
# Сгенерируйте секрет: openssl rand -hex 32  (мин. 32 байта для HS256)
JWT_SECRET_KEY=dev-insecure-secret-change-me-please-32b+
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# true => каждый запрос сверяет сессию с Redis (немедленный logout/удаление, +1 GET);
# false => access stateless, отзыв сессии действует после истечения access
AUTH_VALIDATE_SESSION=false
# Транспорт токена в авторизации: header (Bearer) ИЛИ cookie (HttpOnly) — ЧТО-ТО ОДНО.
#   header (по умолч.) — для SPA/mobile; токен в Authorization-заголовке.
#   cookie — для браузерной сессии; токен в HttpOnly-куке (недоступен JS).
# Cookie работает ТОЛЬКО при AUTH_JWT_ENABLED=true и НЕСОВМЕСТИМ с GLOBAL_API_KEY_ENABLED=true
# (браузеру негде хранить секретный ключ) — иначе приложение упадёт на старте с ошибкой.
AUTH_TOKEN_TRANSPORT=header
AUTH_COOKIE_SECURE=true            # Secure-флаг куки (только HTTPS). В локальном http-dev = false
AUTH_COOKIE_SAMESITE=lax           # lax | strict | none (none требует Secure=true)

# ============================================================
# Global API key gate — защита всего сервиса одним ключом
# ============================================================
# true  => весь API (кроме /health и /docs) требует заголовок X-API-Key
# false => API открыт; защита только на ручках с JWT-зависимостями
GLOBAL_API_KEY_ENABLED=false
GLOBAL_API_KEY=

# ============================================================
# Docs (Swagger / ReDoc / openapi.json)
# ============================================================
# DOCS_ENABLED=false полностью отключает документацию.
# В ПРОДЕ docs показываются ТОЛЬКО если заданы логин+пароль ниже (иначе скрыты).
# Если оба заданы — /docs, /redoc, /openapi.json закрываются HTTP Basic Auth (в т.ч. в dev).
DOCS_ENABLED=true
DOCS_BASIC_AUTH_USER=
DOCS_BASIC_AUTH_PASSWORD=

# --- Health ---
# Показывать снимок активного конфига в /health/ready. Эндпоинт открыт (без авторизации),
# а конфиг раскрывает защитную конфигурацию (rate_limit/режимы авторизации) — поэтому
# в проде по умолчанию СКРЫТ (в dev показывается всегда). true => показывать и в проде.
HEALTH_EXPOSE_CONFIG=false
